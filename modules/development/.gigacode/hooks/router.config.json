{
  "version": 1,
  "stop_block_budget": 2,
  "feature_patterns": [
    "(?:^|/)docs/development/([^/]+)/",
    "(?:^|/)openspec/changes/([^/]+)/"
  ],
  "routes": [
    {
      "event": "UserPromptSubmit",
      "gates": ["preflight_check", "gate_context_inject"]
    },
    {
      "event": "SessionStart",
      "gates": ["gate_context_inject"]
    },
    {
      "event": "SubagentStart",
      "agent_pattern": "^coder$",
      "gates": ["gate_context_inject"]
    },
    {
      "event": "PreToolUse",
      "tool_pattern": "^(Bash|Shell)$",
      "gates": ["git_guard"],
      "safety_critical": true
    },
    {
      "event": "PreToolUse",
      "tool_pattern": "^(Write|WriteFile|Edit|MultiEdit|NotebookEdit)$",
      "gates": ["git_guard"],
      "safety_critical": true
    },
    {
      "event": "PreToolUse",
      "tool_pattern": "^(Write|WriteFile|Edit|MultiEdit|NotebookEdit)$",
      "gates": ["gate_stage_order"],
      "safety_critical": true
    },
    {
      "event": "PreToolUse",
      "tool_pattern": "^(Write|WriteFile|Edit|MultiEdit|NotebookEdit)$",
      "gates": ["gate_spec_structure"]
    },
    {
      "event": "PreToolUse",
      "tool_pattern": "^(Write|WriteFile|Edit|MultiEdit|NotebookEdit)$",
      "gates": ["gate_existing_code"]
    },
    {
      "event": "PreToolUse",
      "tool_pattern": "^(Write|WriteFile|Edit|MultiEdit|NotebookEdit)$",
      "gates": ["gate_scope_guard"]
    },
    {
      "event": "PreToolUse",
      "_comment": "Fail-closed catch-all: any tool id that LOOKS like a file mutator (incl. unmapped MCP/Serena editors not in TOOL_NAME_MAP) still hits the path-protecting write gates, so a write to .gigacode / out-of-scope / machine-owned files cannot slip past via an unknown tool name. re.search + idempotent gate decisions make the overlap with the canonical write routes harmless; read-only tool names (read/find/get/list/search/overview) do not match.",
      "tool_pattern": "(?i)(?:write|edit|insert|create|replace|delete|append|prepend|rename|truncate|patch|mkfile|new_file|put_file|move_file|save)",
      "gates": ["git_guard", "gate_stage_order", "gate_scope_guard"],
      "safety_critical": true
    },
    {
      "event": "PostToolUse",
      "tool_pattern": "^(Write|WriteFile|Edit|MultiEdit|NotebookEdit)$",
      "gates": ["gate_spec_structure", "gate_lint", "gate_clean_code"]
    },
    {
      "event": "Stop",
      "gates": ["validate_development_output", "gate_spec_structure", "gate_build", "gate_verdict", "gate_stage_order", "gate_integrity"]
    }
  ]
}
