{
  "lint": {
    "command": "./gradlew detekt ktlintCheck",
    "applies_to": ["**/*.kt", "**/*.kts", "**/*.java"],
    "timeout_seconds": 180
  },
  "build": {
    "command": "./gradlew build -x test",
    "timeout_seconds": 600
  },
  "test": {
    "command": "./gradlew test"
  },
  "clean_code": {
    "max_file_lines": 400,
    "max_function_lines": 60,
    "placeholder_markers": ["TODO", "FIXME", "XXX"]
  }
}
