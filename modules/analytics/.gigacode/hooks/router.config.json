{
  "version": 1,
  "stop_block_budget": 2,
  "feature_patterns": [
    "(?:^|/)docs/features/([^/]+)/",
    "(?:^|/)openspec/changes/([^/]+)/"
  ],
  "routes": [
    {
      "event": "UserPromptSubmit",
      "gates": ["preflight_check", "gate_context_inject"]
    },
    {
      "event": "SessionStart",
      "gates": ["gate_context_inject"]
    },
    {
      "event": "SubagentStart",
      "agent_pattern": "^(code-mapping|documentation)$",
      "gates": ["gate_context_inject"]
    },
    {
      "event": "PreToolUse",
      "tool_pattern": "^(Bash|Shell)$",
      "gates": ["git_guard"],
      "safety_critical": true
    },
    {
      "event": "PreToolUse",
      "tool_pattern": "^(WriteFile|Edit|NotebookEdit)$",
      "gates": ["git_guard"],
      "safety_critical": true
    },
    {
      "event": "PreToolUse",
      "tool_pattern": "^(WriteFile|Edit|NotebookEdit)$",
      "gates": ["gate_spec_bootstrap"],
      "safety_critical": true
    },
    {
      "event": "PreToolUse",
      "_comment": "Fail-closed catch-all: any tool id that LOOKS like a file mutator (incl. unmapped MCP/Serena editors not in TOOL_NAME_MAP) still hits the path-protecting git_guard, so a write to .gigacode cannot slip past via an unknown tool name. re.search + idempotent decisions make overlap with the canonical write route harmless; read-only tool names (read/find/get/list/search/overview) do not match.",
      "tool_pattern": "(?i)(?:write|edit|insert|create|replace|delete|append|prepend|rename|truncate|patch|mkfile|new_file|put_file|move_file|save)",
      "gates": ["git_guard"],
      "safety_critical": true
    },
    {
      "event": "PostToolUse",
      "tool_pattern": "^(WriteFile|Edit)$",
      "gates": ["gate_techdocs", "gate_final_format"]
    },
    {
      "event": "Stop",
      "gates": ["validate_run_output", "gate_integrity"]
    }
  ]
}
